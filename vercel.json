{
  "ignoreCommand": "if [ \"$VERCEL_ENV\" != \"production\" ]; then exit 0; fi; git diff --quiet HEAD^ HEAD -- ':!docs' ':!*.md' ':!supabase/migrations' ':!.claude'",
  "crons": [
    {
      "path": "/api/cron/update-tracking",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/auto-abandon",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/recovery-emails",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/invoice-health-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/auto-finalize-delivered",
